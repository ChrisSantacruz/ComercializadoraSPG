# ─── Copia a `backend/.env` (local, no se sube a git) o define las mismas claves en tu hosting ───
#
# DESARROLLO: NODE_ENV=development
# PRODUCCIÓN: NODE_ENV=production  (obligatorio JWT_SECRET fuerte; revisa CORS)

# ─── Entorno
NODE_ENV=development

# ─── Base de datos (producción: MongoDB Atlas u otro cluster)
MONGODB_URI=mongodb://localhost:27017/comercializadora_spg

# ─── Servidor
# Render u otros suelen asignar PORT automáticamente (ej. 10000). En local usa 5001.
PORT=5001

# URL del SPA (sin barra final). DEBE coincidir con el origen desde el que abres el front (CORS + redirects OAuth).
FRONTEND_URL=http://localhost:3000
# Origen adicional CORS (opcional, separados por coma)
# ADMIN_URL=
# CORS_EXTRA_ORIGINS=https://andinoexpress.com,https://www.andinoexpress.com

# ─── JWT (producción: secreto largo y aleatorio; el server aborta si falta JWT_SECRET en prod)
JWT_SECRET=your_jwt_secret_here_change_me
JWT_EXPIRE=30d
# JWT_REFRESH_SECRET=

# ─── CORS producción
# Solo si necesitas Postman/curl sin Origin en prod (no recomendado)
# CORS_ALLOW_NO_ORIGIN=true

# ─── Rate limit (/api/*)
# RATE_LIMIT_MAX=400

# ─── Cloudinary (recomendado en prod sin disco persistente para imágenes de productos)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── OAuth Google (Passport en backend; debe coincidir con credenciales y redirect URIs en Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── WOMPI — desarrollo / sandbox
WOMPI_PUBLIC_KEY=pub_test_vCPe0u28F8LelBmQ0FKvosSHMsrQAm7K
WOMPI_PRIVATE_KEY=prv_test_VOjFWhNYZ7mZQOKZf0xX4KKM6LJQAQSO
WOMPI_INTEGRITY_SECRET=test_integrity_IEKn14ygMN0L9P6PlujjkHIKPitLl8a6
WOMPI_EVENTS_SECRET=test_events_KGhXkD3ZZ7ArHpWfIEmPbwVeptF8QA5R
WOMPI_API_URL=https://sandbox.wompi.co/v1

# ─── WOMPI — PRODUCCIÓN (descomenta y rellena; comenta o elimina las de sandbox arriba en el mismo deploy)
# WOMPI_PUBLIC_KEY=pub_prod_xxxxx
# WOMPI_PRIVATE_KEY=prv_prod_xxxxx
# WOMPI_INTEGRITY_SECRET=prod_integrity_xxxxx
# WOMPI_EVENTS_SECRET=prod_events_xxxxx
# WOMPI_API_URL=https://production.wompi.co/v1

# ─── Email (Nodemailer)
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false

# SendGrid (alternativa)
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# SENDGRID_FROM_NAME=

# ─── Web Push (opcional)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ─── Bootstrap admin (solo si lo necesitas en prod)
# ENABLE_ADMIN_BOOTSTRAP=true
# ADMIN_BOOTSTRAP_SECRET=

# Checklist producción:
# [ ] MONGODB_URI de Atlas con usuario solo lectura/escritura necesaria
# [ ] JWT_SECRET único y largo
# [ ] FRONTEND_URL = URL pública exacta del build React (CORS)
# [ ] Misma WOMPI_PUBLIC_KEY en backend y REACT_APP_WOMPI_PUBLIC_KEY en frontend
# [ ] Cloudinary si el hosting borra archivos al redeploy
# [ ] GOOGLE_CLIENT_* y URIs autorizadas apuntando a tu dominio producción
