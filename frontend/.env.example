# ─── Producción (ejemplo — NO pegues secretos en git; usa variables del hosting)
# URL pública del API solo origen, sin /api al final (ej. https://tu-api.onrender.com)
# Debe ser el mismo host donde el backend sirve /uploads y /api.
# REACT_APP_API_URL=https://tu-backend.onrender.com
# Misma clave pública Wompi que WOMPI_PUBLIC_KEY del backend en ese entorno.
# REACT_APP_WOMPI_PUBLIC_KEY=pub_prod_XXXXX
# REACT_APP_ENV=production

# Firebase: la config actual está en src/config/firebase.ts (opcional migrar a REACT_APP_* si prefieres).
